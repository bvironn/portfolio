# Required — bcrypt hash of the admin password
# Generate with: bunx bcryptjs hash "your-password"
ADMIN_PASSWORD_HASH=

# Optional — session token for admin cookie
# If not set, a random UUID is generated per process (sessions won''t survive restart)
ADMIN_SESSION_TOKEN=

# Base URL of the site (used for CSRF origin check on /api/contact)
# Example: https://bairon.me
SITE_URL=
