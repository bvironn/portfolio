---
import Layout from "../layouts/Layout.astro"
import Nav from "../components/Nav.astro"
import Hero from "../components/Hero.astro"
import About from "../components/About.astro"
import Stack from "../components/Stack.astro"
import Projects from "../components/Projects.astro"
import Contact from "../components/Contact.astro"
---

<Layout title="bairon — Full Stack Developer & SysAdmin">
  <Nav />
  <div class="flex flex-col gap-16">
    <Hero />

    <div class="h-px w-full bg-border" />

    <Stack />

    <div class="h-px w-full bg-border" />

    <Projects />

    <div class="h-px w-full bg-border" />

    <About />

    <div class="h-px w-full bg-border" />

    <Contact />

    <footer class="flex flex-col items-center gap-2 pt-4 pb-8">
      <span class="font-mono text-xs text-muted-foreground/50">/* si compila, no lo toques */</span>
      <span class="font-mono text-xs text-muted-foreground/30">bairon.me &copy; 2026</span>
    </footer>
  </div>
</Layout>
