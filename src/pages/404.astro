---
import Layout from "@/layouts/Layout.astro"

Astro.response.status = 404
---

<Layout title="404 — bairon.me" description="Página no encontrada">
  <div class="flex min-h-[80vh] items-center justify-center">
    <div class="flex flex-col gap-2 font-mono text-sm">
      <span class="text-muted-foreground">$ cd /ruta</span>
      <span class="text-red-400">bash: cd: /ruta: No such file or directory</span>
      <a href="/" class="text-foreground hover:underline">$ cd ~</a>
    </div>
  </div>
</Layout>
