---
---

<section id="contacto" class="flex flex-col gap-4">
  <h2 class="font-mono text-sm text-muted-foreground">$ mailto bvirondev@proton.me</h2>

  <form id="contact-form" class="flex flex-col gap-4">
    <div class="flex flex-col gap-1.5">
      <label for="name" class="font-mono text-xs text-muted-foreground">nombre</label>
      <input
        type="text"
        id="name"
        name="name"
        required
        class="rounded-lg border border-border bg-card px-3 py-2 text-sm text-foreground placeholder:text-muted-foreground/40 outline-none transition-colors focus:border-foreground/20 focus:ring-1 focus:ring-foreground/20"
        placeholder="Tu nombre"
      />
    </div>
    <div class="flex flex-col gap-1.5">
      <label for="email" class="font-mono text-xs text-muted-foreground">email</label>
      <input
        type="email"
        id="email"
        name="email"
        required
        class="rounded-lg border border-border bg-card px-3 py-2 text-sm text-foreground placeholder:text-muted-foreground/40 outline-none transition-colors focus:border-foreground/20 focus:ring-1 focus:ring-foreground/20"
        placeholder="tu@email.com"
      />
    </div>
    <div class="flex flex-col gap-1.5">
      <label for="message" class="font-mono text-xs text-muted-foreground">mensaje</label>
      <textarea
        id="message"
        name="message"
        required
        rows="4"
        class="resize-none rounded-lg border border-border bg-card px-3 py-2 text-sm text-foreground placeholder:text-muted-foreground/40 outline-none transition-colors focus:border-foreground/20 focus:ring-1 focus:ring-foreground/20"
        placeholder="Cuéntame sobre tu proyecto..."
      ></textarea>
    </div>
    <div class="flex items-center gap-3">
      <button
        type="submit"
        id="contact-submit"
        class="inline-flex w-fit items-center gap-1.5 rounded-lg bg-foreground px-4 py-2 text-sm font-medium text-background transition-opacity hover:opacity-90 cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed"
      >
        <svg class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.536 21.686a.5.5 0 0 0 .937-.024l6.5-19a.496.496 0 0 0-.635-.635l-19 6.5a.5.5 0 0 0-.024.937l7.93 3.18a2 2 0 0 1 1.112 1.11z"/><path d="m21.854 2.147-10.94 10.939"/></svg>
        <span id="submit-text">Enviar</span>
      </button>
      <span id="contact-status" class="font-mono text-xs text-muted-foreground/60 hidden"></span>
    </div>
  </form>
</section>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement
  const submitBtn = document.getElementById("contact-submit") as HTMLButtonElement
  const submitText = document.getElementById("submit-text") as HTMLSpanElement
  const status = document.getElementById("contact-status") as HTMLSpanElement

  form?.addEventListener("submit", async (e) => {
    e.preventDefault()
    const data = new FormData(form)

    submitBtn.disabled = true
    submitText.textContent = "Enviando..."

    try {
      const res = await fetch("/api/contact", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          name: data.get("name"),
          email: data.get("email"),
          message: data.get("message"),
        }),
      })

      if (res.ok) {
        form.reset()
        status.textContent = "Mensaje enviado"
        status.classList.remove("hidden")
        setTimeout(() => status.classList.add("hidden"), 3000)
      } else {
        status.textContent = "Error al enviar"
        status.classList.remove("hidden")
      }
    } catch {
      status.textContent = "Error de conexion"
      status.classList.remove("hidden")
    } finally {
      submitBtn.disabled = false
      submitText.textContent = "Enviar"
    }
  })
</script>
