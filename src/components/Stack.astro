---
const stack = {
  web: ["TypeScript", "React", "Astro", "Tailwind CSS", "shadcn/ui", "Bun"],
  backend: ["PHP", "Laravel", "MariaDB"],
  infra: ["Docker", "Nginx", "Linux", "Shell", "Pterodactyl"],
}
---

<section id="stack" class="flex flex-col gap-4">
  <div class="overflow-hidden rounded-lg border border-border">
    <!-- Title bar -->
    <div class="flex items-center justify-between border-b border-border bg-card px-4 py-2">
      <span class="font-mono text-xs text-muted-foreground">bairon@dev: ~/stack</span>
      <div class="flex items-center gap-3 text-muted-foreground/50">
        <span class="text-xs leading-none">&#x2500;</span>
        <span class="text-xs leading-none">&#x25A1;</span>
        <span class="text-xs leading-none">&#x2715;</span>
      </div>
    </div>

    <!-- Terminal body -->
    <div class="flex flex-col gap-3 bg-background p-4 font-mono text-sm">
      <span class="text-muted-foreground">$ ls stack/</span>

      {Object.entries(stack).map(([category, techs]) => (
        <div class="flex flex-col gap-1.5">
          <span class="text-muted-foreground">
            {category === "infra" ? "└──" : "├──"} {category}/
          </span>
          <div class="flex flex-wrap gap-1.5 pl-8">
            {techs.map((tech) => (
              <!-- TODO: agregar modal con descripcion/experiencia al hacer click -->
              <button
                type="button"
                class="rounded-md border border-border bg-card px-2 py-0.5 text-xs text-foreground/80 transition-colors hover:border-foreground/30 hover:text-foreground cursor-pointer"
              >
                {tech}
              </button>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
