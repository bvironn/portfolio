---
import { Image } from "astro:assets"
import delitrackImg from "@/assets/delitrack.png"
import finzaImg from "@/assets/finza.png"
import notesAppImg from "@/assets/notes-app.png"

interface Project {
  name: string
  description: string
  url: string
  homepage?: string
  language: string[]
  image?: ImageMetadata
  private?: boolean
}

const projects: Project[] = [
  {
    name: "finza-dashboard",
    description: "Dashboard financiero personal. Reemplaza las hojas de calculo con transacciones, gastos fijos, proyecciones y analytics por mes.",
    url: "https://github.com/bvironn/finza-dashboard",
    language: ["TypeScript", "React", "Hono", "MariaDB", "Drizzle", "shadcn/ui"],
    image: finzaImg,
    private: false,
  },
  {
    name: "delitrack",
    description: "SaaS de gestion de pagos para repartidores. Multi-tenant, roles, liquidaciones por sucursal.",
    url: "https://github.com/bvironn/delitrack",
    language: ["TypeScript", "Astro", "React", "PostgreSQL", "shadcn/ui"],
    image: delitrackImg,
    private: true,
  },
  {
    name: "notes-app",
    description: "App de notas con editor Markdown en tiempo real. Preview, listas interactivas, checkboxes, temas dark/light y almacenamiento local.",
    url: "https://github.com/bvironn/notes-app",
    language: ["TypeScript", "Astro", "React", "shadcn/ui", "MDEditor"],
    image: notesAppImg,
    private: false,
  },
]
---

<section id="proyectos" class="flex flex-col gap-4">
  <h2 class="font-mono text-sm text-muted-foreground">$ ls projects/</h2>

  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
    {projects.map((project, index) => {
      const isLastOdd = index === projects.length - 1 && projects.length % 2 !== 0;
      return (
        <div class:list={[
          "group overflow-hidden rounded-lg border border-border bg-card transition-colors hover:border-foreground/20",
          isLastOdd ? "sm:col-span-2 flex flex-col sm:flex-row" : "flex flex-col",
        ]}>
          {project.image && !project.private && (
            <a
              href={project.homepage ?? project.url}
              target="_blank"
              rel="noopener noreferrer"
              class:list={[
                "overflow-hidden bg-muted/30",
                isLastOdd ? "sm:w-1/2" : "",
              ]}
            >
              <Image
                src={project.image}
                alt={`${project.name} preview`}
                class:list={[
                  "w-full object-cover brightness-110 transition-all group-hover:scale-[1.02] group-hover:brightness-125",
                  isLastOdd ? "h-full border-b sm:border-b-0 sm:border-r border-border" : "aspect-video border-b border-border",
                ]}
                widths={[320, 480, 640]}
                sizes={isLastOdd ? "(max-width: 640px) 100vw, 50vw" : "(max-width: 640px) 100vw, 320px"}
              />
            </a>
          )}
          {project.image && project.private && (
            <div class:list={[
              "overflow-hidden bg-muted/30",
              isLastOdd ? "sm:w-1/2" : "",
            ]}>
              <Image
                src={project.image}
                alt={`${project.name} preview`}
                class:list={[
                  "w-full object-cover brightness-110",
                  isLastOdd ? "h-full border-b sm:border-b-0 sm:border-r border-border" : "aspect-video border-b border-border",
                ]}
                widths={[320, 480, 640]}
                sizes={isLastOdd ? "(max-width: 640px) 100vw, 50vw" : "(max-width: 640px) 100vw, 320px"}
              />
            </div>
          )}
          <div class:list={[
            "flex flex-1 flex-col gap-2 p-3",
            isLastOdd ? "sm:w-1/2 sm:justify-center sm:p-5" : "",
          ]}>
            <div class="flex items-center gap-2">
              <span class="font-mono text-sm font-medium text-foreground">
                {project.name}
              </span>
              {project.private && (
                <span class="rounded-md border border-border px-1.5 py-0.5 text-xs text-muted-foreground/60">
                  privado
                </span>
              )}
            </div>
            <p class="text-xs text-muted-foreground">{project.description}</p>
            <div class="flex flex-wrap gap-1">
              {project.language.map((lang) => (
                <span class="rounded-md bg-secondary px-1.5 py-0.5 text-[10px] text-muted-foreground">
                  {lang}
                </span>
              ))}
            </div>
            <div class="mt-auto flex items-center gap-2 pt-1">
              {!project.private ? (
                <a
                  href={project.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 rounded-md border border-border px-2 py-1 text-xs text-muted-foreground transition-colors hover:text-foreground"
                >
                  <svg class="size-3" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                  Code
                </a>
              ) : (
                <span class="inline-flex items-center gap-1.5 rounded-md border border-border px-2 py-1 text-xs text-muted-foreground/40 cursor-not-allowed">
                  <svg class="size-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                  Code
                </span>
              )}
              {project.homepage && (
                <a
                  href={project.homepage}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 rounded-md border border-border px-2 py-1 text-xs text-muted-foreground transition-colors hover:text-foreground"
                >
                  <svg class="size-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
                  Preview
                </a>
              )}
            </div>
          </div>
        </div>
      );
    })}
  </div>
</section>
